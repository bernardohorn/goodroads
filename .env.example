# Copie este arquivo para .env na raiz do projeto e preencha os valores.
# Depois adicione "- .env" em pubspec.yaml > flutter > assets (se ainda não existir).

# API principal do GoodRoads
URL_BASE_API=https://api.goodroads.grb.local

# Google Maps (Android: local.properties | iOS: Info.plist GMSApiKey | Web: abaixo)
GOOGLE_MAPS_API_KEY=

# Consulta CPF/CNPJ (ex.: Brasil API, ReceitaWS, serviço interno da GRB)
CPF_CNPJ_API_URL=https://api.exemplo.com/v1
CPF_CNPJ_API_TOKEN=

# Firebase — defina true após configurar com: dart run flutterfire_cli:flutterfire configure
FIREBASE_HABILITADO=false
