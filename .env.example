# Copie este arquivo para .env na raiz do projeto e preencha os valores.
# Depois adicione "- .env" em pubspec.yaml > flutter > assets (se ainda não existir).

# API principal do GoodRoads (inclui prefixo /api)
URL_BASE_API=http://localhost:3001/api

# Google Maps (Android: local.properties | iOS: Info.plist GMSApiKey | Web/Windows: abaixo)
GOOGLE_MAPS_API_KEY=

# Consulta CPF/CNPJ (ex.: Brasil API, ReceitaWS, serviço interno da GRB)
CPF_CNPJ_API_URL=https://api.exemplo.com/v1
CPF_CNPJ_API_TOKEN=

# Firebase — habilite após preencher as credenciais abaixo
FIREBASE_HABILITADO=true
FIREBASE_API_KEY=
FIREBASE_APP_ID_ANDROID=
FIREBASE_APP_ID_IOS=
FIREBASE_APP_ID_WEB=
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_AUTH_DOMAIN=
